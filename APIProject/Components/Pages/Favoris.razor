@page "/favoris"
@using APIProject.Services
@inject FavoriService FavoriSvc
@inject AuthService Auth
@inject NavigationManager Nav
@rendermode InteractiveServer

<section class="page-shell">
    <h1>Mes Favoris</h1>

    @if (!Auth.EstConnecte)
    {
        <div class="card-box">
            <p>Tu dois être <a href="/login">connecté(e)</a>.</p>
        </div>
    }
    else
    {
        var favoris = FavoriSvc.GetFavoris(Auth.UtilisateurActuel);

        @if (favoris.Count == 0)
        {
            <div class="card-box">
                <p class="muted">Aucun favori pour l'instant.</p>
            </div>
        }
        else
        {
            <div class="fav-grid">
                @foreach (var f in favoris)
                {
                    <div class="card-box fav-item">
                        <img src="@f.ImageUrl" alt="@f.Nom" />
                        <div>
                            <h3>@f.Nom</h3>

                            @if (idEnEdition == f.Id)
                            {
                                <input @bind="noteEnEdition" placeholder="Ta note..." />
                                <div class="actions">
                                    <button @onclick="() => SauvegarderNote(f.Id)">Sauvegarder</button>
                                    <button class="ghost" @onclick="AnnulerEdition">Annuler</button>
                                </div>
                            }
                            else
                            {
                                <p>Note : @(f.Note == "" ? "Aucune note" : f.Note)</p>
                                <div class="actions">
                                    <button @onclick="() => CommencerEdition(f.Id, f.Note)">Modifier</button>
                                    <button class="danger" @onclick="() => FavoriSvc.SupprimerFavori(Auth.UtilisateurActuel, f.Id)">Supprimer</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
</section>

@code {
    // idEnEdition indique quel favori est actuellement en mode edition.
    int idEnEdition = -1;
    string noteEnEdition = "";

    void CommencerEdition(int id, string noteActuelle)
    {
        // On pre-remplit l'input avec la note existante.
        idEnEdition = id;
        noteEnEdition = noteActuelle;
    }

    void SauvegarderNote(int id)
    {
        // Sauvegarde de la note puis sortie du mode edition.
        FavoriSvc.ModifierNote(Auth.UtilisateurActuel, id, noteEnEdition);
        idEnEdition = -1;
        noteEnEdition = "";
    }

    void AnnulerEdition()
    {
        idEnEdition = -1;
        noteEnEdition = "";
    }
}