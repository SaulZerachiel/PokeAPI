@page "/"
@inject PokemonService PokemonSvc
@inject FavoriService FavoriSvc
@inject AuthService Auth
@inject NavigationManager Nav
@rendermode InteractiveServer

<section class="page-shell">
    <h1>Recherche de Pokemon</h1>

    @if (afficherPopup)
    {
        <div class="toast-success">
            Pokemon ajouté aux favoris !
        </div>
    }

    @if (!Auth.EstConnecte)
    {
        <div class="card-box">
            <p><a href="/login">Connecte-toi</a> pour utiliser l'application.</p>
        </div>
    }
    else
    {
        <div class="card-box">
            <p>
                Bienvenue sur mon API, @Auth.UtilisateurActuel !
                <button class="ghost" @onclick="SeDeconnecter">Déconnexion</button>
            </p>

            <div class="search-row">
                <input @bind="recherche" placeholder="Entrez un nom (ex: pikachu)" />
                <button @onclick="Chercher">Rechercher</button>
            </div>

            @if (chargement)
            {
                <p class="muted">Chargement...</p>
            }
            else if (pokemon != null)
            {
                <div class="pokemon-card">
                    <img src="@pokemon.ImageUrl" alt="@pokemon.Name" />
                    <div>
                        <h2>@Majuscule(pokemon.Name)</h2>
                        <p>Taille : @pokemon.Height</p>
                        <p>Poids : @pokemon.Weight</p>
                        <p>Type : @string.Join(", ", pokemon.Types)</p>
                        <button @onclick="AjouterAuxFavoris">Ajouter aux favoris</button>
                    </div>
                </div>
            }
            else if (erreur != "")
            {
                <p class="notice">@erreur</p>
            }
        </div>
    }
</section>

@code {
    // Etat local de la page (saisie, resultat, feedback utilisateur).
    string recherche = "";
    Pokemon? pokemon = null;
    bool chargement = false;
    string erreur = "";
    bool afficherPopup = false;

    string Majuscule(string mot)
    {
        if (string.IsNullOrEmpty(mot)) return mot;
        return char.ToUpper(mot[0]) + mot.Substring(1);
    }

    async Task Chercher()
    {
        // On reset l'etat avant chaque nouvelle requete.
        erreur = "";
        pokemon = null;
        chargement = true;

        try
        {
            pokemon = await PokemonSvc.GetPokemon(recherche);
            if (pokemon == null)
            {
                erreur = "Pokémon non trouvé.";
            }
        }
        catch
        {
            // Ici on gere surtout les erreurs reseau/API.
            erreur = "Erreur lors de la recherche.";
        }

        chargement = false;
    }

    async Task AjouterAuxFavoris()
    {
        if (pokemon != null)
        {
            var utilisateur = Auth.UtilisateurActuel;
            if (string.IsNullOrWhiteSpace(utilisateur))
            {
                return;
            }

            // On convertit le Pokemon courant en Favori persistant en memoire.
            var favori = new Favori
            {
                Nom = pokemon.Name,
                Note = "",
                ImageUrl = pokemon.ImageUrl
            };
            FavoriSvc.AjouterFavori(utilisateur, favori);

            // Petit feedback visuel temporaire.
            afficherPopup = true;
            await Task.Delay(2000);
            afficherPopup = false;
        }
    }

    void SeDeconnecter()
    {
        Auth.Deconnecter();
        Nav.NavigateTo("/login");
    }
}